# Copy to .env and fill in. Do not commit .env.
ASPIRE_API_BASE=https://cloud-api.youraspire.com
ASPIRE_CLIENT_ID=your_client_id
ASPIRE_SECRET=your_secret

# Fixed inventory location on every receipt (B4 in Excel is ignored)
ASPIRE_INVENTORY_LOCATION_ID=1

# Aspire import
# ASPIRE_EXCEL_SHEET=Invoice_Import
# ASPIRE_LINE_START_ROW=10
# ASPIRE_RECEIPTS_READY=Receipts - Ready
# ASPIRE_DEFAULT_BRANCH=MD Nursery & Landscaping
# ASPIRE_EXCEL_TEMPLATE=Receipts - Ready\PR Template.xlsx

# OpenAI IDP (scripts/process_invoices.py)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o
IDP_CONFIDENCE_THRESHOLD=0.85
IDP_TAX_MULTIPLIER=1.06
# HD Fowler: always use Turf vendor (never Waterworks) for IDP + import
# IDP_HD_FOWLER_VENDOR_NAME=H.D. Fowler Company {Turf}
# IDP uses exports/catalog_items.csv — refresh before IDP:
#   py scripts/export_reference_data.py --out exports
# IDP_CATALOG_CSV=exports/catalog_items.csv
# IDP_CATALOG_ITEM_TYPE=Material
# Catalog matching is local (catalog is not sent to OpenAI).
# IDP_VENDORS_CSV=exports/vendors.csv
# IDP_INVOICES_INCOMING=Receipts - Ready\Invoices - Ready
# IDP_INVOICES_PROCESSED=Receipts - Ready\Invoices - Processed
# IDP_REVIEW_DASHBOARD=Receipts - Ready\review_dashboard.txt
